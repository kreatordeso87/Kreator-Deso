<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kreator Deso App</title>
    <style>
        /* Mengatur agar halaman bersih tanpa margin bawaan browser */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #ffffff;
        }

        /* Wadah pembungkus untuk memotong toolbar atas */
        .embed-container {
            width: 100%;
            height: 100vh; 
            overflow: hidden; 
            position: relative;
        }

        /* Mengatur posisi iframe agar naik ke atas dan menyembunyikan menu */
        .embed-container iframe {
            width: 100%;
            /* Tinggi layar penuh + 55px (tinggi menu yang dipotong) */
            height: calc(100vh + 55px); 
            position: absolute;
            /* Menggeser iframe ke atas sebesar 55px untuk menyembunyikan toolbar */
            top: -55px; 
            left: 0;
            border: none;
        }
    </style>
</head>
<body>

    <div class="embed-container">
        <iframe src="https://aistudio.google.com/apps/bb616346-2168-416d-a6a7-11598e2738d1?showPreview=true&showAssistant=true&project=gen-lang-client-0999383054&fullscreenApplet=true"></iframe>
    </div>

</body>
</html>
